{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "simple-assets",
  "main": "src/index.ts",
  "compatibility_date": "2025-08-12",
  "observability": { "enabled": true },
  "assets": {
    "directory": "./assets",
    "binding": "ASSETS",
  },
  "routes": [
    {
      "pattern": "assets.your-domain.com",
      "zone_name": "your-domain.com",
      "custom_domain": true,
    },
  ],
}
